# ── Notification Settings ──────────────────────────────────────

# Twilio SMS (optional - leave blank to disable SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1XXXXXXXXXX
TWILIO_TO_NUMBERS=+1XXXXXXXXXX,+1XXXXXXXXXX

# Email SMTP (optional - leave blank to disable email)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=you@example.com,friend@example.com

# ── Monitoring Settings ───────────────────────────────────────

# How often to check (in minutes)
CHECK_INTERVAL_MINUTES=5

# Which rivers to monitor (comma-separated)
# Options: middle_fork, main_salmon, selway
RIVERS=middle_fork,main_salmon,selway

# Date range to monitor (YYYY-MM-DD format)
# Defaults to the current year's control season: May 28 - Sep 3
DATE_START=
DATE_END=

# ── Advanced ──────────────────────────────────────────────────

# Add random jitter to avoid detection (seconds)
JITTER_MAX_SECONDS=30

# Path for state tracking database
STATE_DB_PATH=data/state.json

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
